# Supabase — copy to .env.local and fill with your project values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only (Project Settings → API → Service role). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Gotenberg HTML→PDF service URL (server-only).
GOTENBERG_URL=https://pdf.example.com
